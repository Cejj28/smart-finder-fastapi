# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string from Render (or local Postgres for dev).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
# Render copies this exactly from the "Internal Database URL" of your PostgreSQL service.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# CORS — set to your deployed web frontend URL to restrict origins in production.
# Leave as * during development.
FRONTEND_URL=*
