# ── LOCAL DEVELOPMENT ─────────────────────────────────────────────────────────
# Points FastAPI directly at Django's local SQLite file.
# No PostgreSQL installation needed for local testing.
DATABASE_URL=sqlite+aiosqlite:///../smart-finder-backend/db.sqlite3

# CORS — leave as * for local dev
FRONTEND_URL=*

# ── PRODUCTION (Render) ────────────────────────────────────────────────────────
# Replace the DATABASE_URL above with the Internal Database URL from Render.
# Render format:  postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://USER:PASSWORD@dpg-xxxxx.render.com:5432/smartfinderdb
